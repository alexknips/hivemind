# HiveMind self-hosted cell — environment variables
# Copy to .env and fill in values before running `docker compose up`.

# --- Required for production ---

# Admin bearer token for the POST /v1/tenants provisioning endpoint.
# Generate with: openssl rand -hex 32
HIVEMIND_ADMIN_KEY=change-me-before-production

# Postgres password for the bundled postgres service.
# Generate with: openssl rand -hex 16
POSTGRES_PASSWORD=change-me-before-production

# --- Optional ---

# Port the HTTP API (and SPA) listens on inside the container.
# The default (8080) is published on the same host port.
# HIVEMIND_PORT=8080

# Enable the Layer-3 ingest classifier (Claude Haiku).
# When set, captured decisions are automatically classified on write.
# ANTHROPIC_API_KEY=sk-ant-...

# Comma-separated origins allowed for browser cross-origin requests.
# Needed when your SPA is served from a different origin than the API.
# Example: HIVEMIND_CORS_ORIGINS=https://app.example.com
# HIVEMIND_CORS_ORIGINS=

# --- WorkOS (optional, for OIDC login — self-hosted cells typically omit this) ---
# See docs/SELF_HOSTING.md for the no-WorkOS auth story.
# WORKOS_DOMAIN=
# WORKOS_JWKS_URL=
# WORKOS_AUDIENCE=
