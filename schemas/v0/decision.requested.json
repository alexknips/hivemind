{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://hivemind.local/schemas/v0/decision.requested.json",
  "title": "decision.requested event",
  "type": "object",
  "additionalProperties": false,
  "required": ["event_uuid", "correlation_id", "type", "actor_id", "source", "source_ref", "payload"],
  "properties": {
    "event_id": { "type": ["integer", "null"], "minimum": 1 },
    "event_uuid": { "type": "string", "format": "uuid" },
    "correlation_id": { "type": "string", "minLength": 1 },
    "causation_event_id": { "type": ["integer", "null"], "minimum": 1 },
    "type": { "const": "decision.requested" },
    "actor_id": { "type": "string", "minLength": 1 },
    "source": { "enum": ["cli", "agent", "slack", "api"] },
    "source_ref": { "type": "string", "minLength": 1 },
    "ts": { "type": ["string", "null"], "format": "date-time" },
    "payload": {
      "type": "object",
      "additionalProperties": false,
      "required": ["topic_keys", "decision_id", "reason", "priority", "required_owner_id", "authority_class", "requested_by", "client_request_id"],
      "properties": {
        "topic_keys": { "$ref": "#/$defs/non_empty_id_array" },
        "decision_id": { "anyOf": [{ "$ref": "#/$defs/id" }, { "type": "null" }] },
        "reason": { "type": "string", "minLength": 1 },
        "priority": { "$ref": "#/$defs/priority" },
        "required_owner_id": { "anyOf": [{ "$ref": "#/$defs/id" }, { "type": "null" }] },
        "authority_class": { "type": "string", "minLength": 1 },
        "requested_by": { "$ref": "#/$defs/id" },
        "client_request_id": { "$ref": "#/$defs/id" }
      }
    }
  },
  "$defs": {
    "id": { "type": "string", "minLength": 1 },
    "priority": { "enum": ["P0", "P1", "P2", "P3", "P4"] },
    "non_empty_id_array": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/id" },
      "uniqueItems": true
    }
  }
}
