{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://hivemind.local/schemas/v0/notification.acknowledged.json",
  "title": "notification.acknowledged event",
  "type": "object",
  "additionalProperties": false,
  "required": ["event_uuid", "correlation_id", "type", "actor_id", "source", "source_ref", "payload"],
  "properties": {
    "event_id": { "type": ["integer", "null"], "minimum": 1 },
    "event_uuid": { "type": "string", "format": "uuid" },
    "correlation_id": { "type": "string", "minLength": 1 },
    "causation_event_id": { "type": ["integer", "null"], "minimum": 1 },
    "type": { "const": "notification.acknowledged" },
    "actor_id": { "type": "string", "minLength": 1 },
    "source": { "enum": ["cli", "agent", "human", "slack", "api"] },
    "source_ref": { "type": "string", "minLength": 1 },
    "ts": { "type": ["string", "null"], "format": "date-time" },
    "payload": {
      "type": "object",
      "additionalProperties": false,
      "required": ["notification_id", "ack_at", "snooze_until"],
      "properties": {
        "notification_id": { "$ref": "#/$defs/id" },
        "ack_at": { "type": "string", "format": "date-time" },
        "snooze_until": {
          "type": ["string", "null"],
          "format": "date-time"
        }
      }
    }
  },
  "$defs": {
    "id": { "type": "string", "minLength": 1 }
  }
}
