{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://hivemind.local/schemas/v0/ingest.batch_received.json",
  "title": "ingest.batch_received event",
  "type": "object",
  "additionalProperties": false,
  "required": ["event_uuid", "type", "actor_id", "source", "payload"],
  "properties": {
    "event_id": { "type": ["integer", "null"], "minimum": 1 },
    "event_uuid": { "type": "string", "format": "uuid" },
    "correlation_id": { "type": ["string", "null"], "minLength": 1 },
    "causation_event_id": { "type": ["integer", "null"], "minimum": 1 },
    "type": { "const": "ingest.batch_received" },
    "actor_id": { "type": "string", "minLength": 1 },
    "source": { "enum": ["cli", "agent", "human", "slack", "api"] },
    "source_ref": { "type": ["string", "null"], "minLength": 1 },
    "ts": { "type": ["string", "null"], "format": "date-time" },
    "payload": {
      "type": "object",
      "additionalProperties": false,
      "required": ["batch_id", "agent_tool", "session_id", "turns"],
      "properties": {
        "batch_id": { "type": "string", "minLength": 1 },
        "agent_tool": { "type": "string", "minLength": 1 },
        "session_id": { "type": "string", "minLength": 1 },
        "turns": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["turn_id", "role", "text", "truncated"],
            "properties": {
              "turn_id": { "type": "string" },
              "role": { "type": "string", "minLength": 1 },
              "text": { "type": "string" },
              "truncated": { "type": "boolean" }
            }
          }
        }
      }
    }
  }
}
