{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://hivemind.local/schemas/v0/hypothesis.recorded.json",
  "title": "hypothesis.recorded event",
  "type": "object",
  "additionalProperties": false,
  "required": ["event_uuid", "type", "actor_id", "source", "payload"],
  "properties": {
    "event_id": { "type": ["integer", "null"], "minimum": 1 },
    "event_uuid": { "type": "string", "format": "uuid" },
    "correlation_id": { "type": ["string", "null"], "minLength": 1 },
    "causation_event_id": { "type": ["integer", "null"], "minimum": 1 },
    "type": { "const": "hypothesis.recorded" },
    "actor_id": { "type": "string", "minLength": 1 },
    "source": { "enum": ["cli", "agent", "slack", "api"] },
    "source_ref": { "type": ["string", "null"], "minLength": 1 },
    "ts": { "type": ["string", "null"], "format": "date-time" },
    "payload": {
      "type": "object",
      "additionalProperties": false,
      "required": ["hypothesis_id", "statement"],
      "properties": {
        "hypothesis_id": { "type": "string", "minLength": 1 },
        "statement": { "type": "string", "minLength": 1 }
      }
    }
  }
}
