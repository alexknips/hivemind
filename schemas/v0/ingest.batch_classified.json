{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://hivemind.local/schemas/v0/ingest.batch_classified.json",
  "title": "ingest.batch_classified event",
  "type": "object",
  "additionalProperties": false,
  "required": ["event_uuid", "type", "actor_id", "source", "payload"],
  "properties": {
    "event_id": { "type": ["integer", "null"], "minimum": 1 },
    "event_uuid": { "type": "string", "format": "uuid" },
    "correlation_id": { "type": ["string", "null"], "minLength": 1 },
    "causation_event_id": { "type": ["integer", "null"], "minimum": 1 },
    "type": { "const": "ingest.batch_classified" },
    "actor_id": { "type": "string", "minLength": 1 },
    "source": { "enum": ["cli", "agent", "human", "slack", "api"] },
    "source_ref": { "type": ["string", "null"], "minLength": 1 },
    "ts": { "type": ["string", "null"], "format": "date-time" },
    "payload": {
      "type": "object",
      "additionalProperties": false,
      "required": ["batch_id", "classifier_model", "schema_version", "captures"],
      "properties": {
        "batch_id": { "type": "string", "minLength": 1 },
        "classifier_model": { "type": "string", "minLength": 1 },
        "schema_version": { "type": "string", "minLength": 1 },
        "captures": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["kind", "title", "rationale", "topic_keys", "evidence_ids", "options", "chosen_option", "confidence"],
            "properties": {
              "kind": {
                "type": "string",
                "enum": ["decision", "evidence", "hypothesis", "blocker", "decision-request", "notification"]
              },
              "title": { "type": "string", "minLength": 1 },
              "rationale": { "type": "string", "minLength": 1 },
              "topic_keys": {
                "type": "array",
                "items": { "type": "string" }
              },
              "evidence_ids": {
                "type": "array",
                "items": { "type": "string" }
              },
              "options": {
                "oneOf": [
                  { "type": "array", "items": { "type": "string" } },
                  { "type": "null" }
                ]
              },
              "chosen_option": {
                "oneOf": [
                  { "type": "string" },
                  { "type": "null" }
                ]
              },
              "confidence": { "type": "number", "minimum": 0.0, "maximum": 1.0 }
            }
          }
        }
      }
    }
  }
}
