---
import '../styles/global.css';
const base = import.meta.env.BASE_URL;
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>HiveMind — Honesty-backed Decision Memory</title>
  <meta name="description" content="Your wiki says what was decided. HiveMind proves it — with options, evidence, and provenance no one can quietly rewrite. Decision memory for humans and agents." />
  <link rel="icon" type="image/svg+xml" href={`${base}favicon.svg`} />
</head>
<body class="bg-gray-950 text-gray-100 antialiased">

  <!-- Nav -->
  <header class="border-b border-gray-800 sticky top-0 z-50 bg-gray-950/90 backdrop-blur">
    <nav class="max-w-6xl mx-auto px-6 h-16 flex items-center justify-between">
      <a href={base} class="flex items-center gap-2 font-bold text-lg text-white">
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
          <circle cx="12" cy="12" r="3" fill="#818cf8"/>
          <circle cx="4" cy="6" r="2" fill="#6366f1"/>
          <circle cx="20" cy="6" r="2" fill="#6366f1"/>
          <circle cx="4" cy="18" r="2" fill="#6366f1"/>
          <circle cx="20" cy="18" r="2" fill="#6366f1"/>
          <line x1="12" y1="12" x2="4" y2="6" stroke="#4f46e5" stroke-width="1.5"/>
          <line x1="12" y1="12" x2="20" y2="6" stroke="#4f46e5" stroke-width="1.5"/>
          <line x1="12" y1="12" x2="4" y2="18" stroke="#4f46e5" stroke-width="1.5"/>
          <line x1="12" y1="12" x2="20" y2="18" stroke="#4f46e5" stroke-width="1.5"/>
        </svg>
        HiveMind
      </a>
      <div class="flex items-center gap-6">
        <a href={`${base}guides/mcp-setup/`} class="text-sm text-gray-400 hover:text-white transition-colors">MCP Setup</a>
        <a href={`${base}getting-started/install/`} class="text-sm text-gray-400 hover:text-white transition-colors">Docs</a>
        <a href="https://github.com/alexknips/hivemind" class="text-sm text-gray-400 hover:text-white transition-colors">GitHub</a>
        <a href={`${base}guides/mcp-setup/`} class="text-sm bg-indigo-600 hover:bg-indigo-500 text-white px-4 py-1.5 rounded-md transition-colors font-medium">
          Connect Agent &rarr;
        </a>
      </div>
    </nav>
  </header>

  <main>

    <!-- Hero -->
    <section class="max-w-6xl mx-auto px-6 pt-24 pb-20 text-center">
      <div class="inline-flex items-center gap-2 bg-indigo-950 border border-indigo-800 text-indigo-300 text-xs px-3 py-1.5 rounded-full mb-8">
        <span class="w-1.5 h-1.5 rounded-full bg-indigo-400"></span>
        MCP-native &middot; stdio + HTTP &middot; 12 tools &middot; works with Claude, Codex, Cursor
      </div>
      <h1 class="text-5xl sm:text-6xl font-bold text-white leading-tight mb-6">
        The wiki says what was decided.<br/>
        <span class="text-indigo-400">It cannot prove it.</span>
      </h1>
      <p class="text-xl text-gray-400 max-w-2xl mx-auto mb-10 leading-relaxed">
        Wiki pages are written after the fact &mdash; options not taken are forgotten, evidence is paraphrased,
        and anyone can silently edit the rationale to match what actually happened.
        HiveMind captures decisions the moment they&rsquo;re made: with the options you weighed,
        the evidence you had, and a provenance trail no one can rewrite.
      </p>

      <!-- Primary CTA: MCP -->
      <div class="max-w-2xl mx-auto mb-6">
        <div class="bg-gray-900 border border-indigo-800 rounded-xl p-6 text-left">
          <div class="text-xs font-mono text-indigo-400 mb-3 uppercase tracking-wide">Connect your agent &mdash; Claude Code, Cursor, Codex</div>
          <div class="bg-gray-950 rounded-lg p-4 font-mono text-sm text-gray-300 mb-3">
            <div class="text-gray-500 text-xs mb-2">// hosted &mdash; open beta, no install, no key</div>
            <div><span class="text-emerald-300">claude mcp add</span> --transport http hivemind \</div>
            <div>&nbsp;&nbsp;<span class="text-indigo-300">https://hivemind-tti3sa.fly.dev/mcp</span></div>
          </div>
          <p class="text-gray-400 text-sm mb-3">Then <span class="text-gray-200">sign in with GitHub or Google</span> &mdash; you&rsquo;re connected. Agents call 12 tools to capture and query decisions; nothing to install.</p>
          <div class="bg-gray-950/60 rounded-lg p-3 font-mono text-xs text-gray-400">
            <span class="text-gray-500">// prefer to self-host?</span> &nbsp;<span class="text-emerald-300">claude mcp add</span> hivemind -- hivemind mcp
          </div>
        </div>
      </div>

      <div class="flex flex-col sm:flex-row gap-3 justify-center mb-4">
        <a href={`${base}demo/`} class="bg-emerald-600 hover:bg-emerald-500 text-white px-6 py-3 rounded-lg font-semibold text-base transition-colors">
          Explore a real decision &rarr;
        </a>
        <a href={`${base}guides/mcp-setup/`} class="bg-indigo-600 hover:bg-indigo-500 text-white px-6 py-3 rounded-lg font-semibold text-base transition-colors">
          Connect your agent &rarr;
        </a>
        <a href={`${base}getting-started/install/`} class="border border-gray-700 hover:border-gray-500 text-gray-300 hover:text-white px-6 py-3 rounded-lg font-semibold text-base transition-colors">
          Self-host guide
        </a>
      </div>
      <p class="text-sm text-gray-500 mb-8">See how a real decision was made, step by step &mdash; options, evidence, provenance. No signup, no install.</p>
    </section>

    <!-- Hosted API callout -->
    <section class="border-t border-gray-800 bg-gray-900/30">
      <div class="max-w-6xl mx-auto px-6 py-16">
        <div class="grid md:grid-cols-2 gap-8">
          <!-- Managed / Live -->
          <div class="bg-gradient-to-br from-indigo-950 to-purple-950 border border-indigo-700 rounded-xl p-8">
            <div class="flex items-center gap-2 mb-4">
              <span class="w-2 h-2 rounded-full bg-emerald-400 animate-pulse"></span>
              <span class="text-xs font-mono text-emerald-400 uppercase tracking-wide">Live API</span>
            </div>
            <h3 class="text-xl font-bold text-white mb-3">Managed HiveMind</h3>
            <p class="text-gray-300 text-sm leading-relaxed mb-4">
              No local install. Connect via remote MCP at
              <code class="text-indigo-300">hivemind-tti3sa.fly.dev/mcp</code>.
              Sign in with GitHub or Google &mdash; no API key to paste.
            </p>
            <p class="text-gray-400 text-sm mb-6">
              Early access &mdash; drop a note to get connected.
            </p>
            <a href="mailto:alex.knips@gmail.com" class="inline-block bg-indigo-600 hover:bg-indigo-500 text-white px-5 py-2 rounded-lg text-sm font-medium transition-colors">
              Request access &rarr;
            </a>
          </div>
          <!-- Self-host -->
          <div class="bg-gray-900 border border-gray-800 rounded-xl p-8">
            <div class="flex items-center gap-2 mb-4">
              <span class="text-xs font-mono text-gray-500 uppercase tracking-wide">Self-host</span>
            </div>
            <h3 class="text-xl font-bold text-white mb-3">Run your own</h3>
            <p class="text-gray-300 text-sm leading-relaxed mb-4">
              Your instance, your data &mdash; nothing phones home. Three commands spin
              up a full cell: clone, set one secret, <code class="text-indigo-300">docker compose up</code>.
              Connect your agent via MCP in under five minutes.
            </p>
            <div class="bg-gray-950 rounded-lg p-3 font-mono text-xs text-gray-400 mb-6">
              docker compose up --build -d
            </div>
            <a href={`${base}getting-started/install/`} class="inline-block border border-gray-700 hover:border-gray-500 text-gray-300 hover:text-white px-5 py-2 rounded-lg text-sm font-medium transition-colors">
              Self-host guide &rarr;
            </a>
          </div>
        </div>
      </div>
    </section>

    <!-- Problem -->
    <section class="max-w-6xl mx-auto px-6 py-20">
      <h2 class="text-3xl font-bold text-white text-center mb-4">The wiki habit makes decisions unverifiable</h2>
      <p class="text-gray-400 text-center max-w-xl mx-auto mb-16">
        Every team documents decisions. Almost none can verify what was decided, when, by whom,
        or whether the rationale has been quietly updated since.
      </p>
      <div class="grid md:grid-cols-3 gap-8">
        <div class="bg-gray-900 border border-gray-800 rounded-xl p-6">
          <div class="text-2xl mb-3">&#x1F4CB;</div>
          <h3 class="font-semibold text-white mb-2">Written after the fact</h3>
          <p class="text-gray-400 text-sm leading-relaxed">
            By the time a decision makes it to the wiki, the options not taken are already gone,
            the evidence is a summary of a summary, and the reasoning has been cleaned up
            to match the outcome. The record is a reconstruction, not the original.
          </p>
        </div>
        <div class="bg-gray-900 border border-gray-800 rounded-xl p-6">
          <div class="text-2xl mb-3">&#x1F916;</div>
          <h3 class="font-semibold text-white mb-2">No actor, no dissent</h3>
          <p class="text-gray-400 text-sm leading-relaxed">
            Documents have no who. When a human overrides an agent call, or two engineers
            disagree, that signal disappears into the last-saved version.
            An agent picking up the work has no structured place to learn what was tried or why.
          </p>
        </div>
        <div class="bg-gray-900 border border-gray-800 rounded-xl p-6">
          <div class="text-2xl mb-3">&#x270F;&#xFE0F;</div>
          <h3 class="font-semibold text-white mb-2">Silently rewritable</h3>
          <p class="text-gray-400 text-sm leading-relaxed">
            A wiki page that says &ldquo;we chose X because of Y&rdquo; offers no proof that Y was the real reason,
            or that the rationale hasn&rsquo;t been quietly updated since.
            The record and the reasoning can both change without a trace.
          </p>
        </div>
      </div>
    </section>

    <!-- How it works / Three layers -->
    <section class="border-t border-gray-800 bg-gray-900/30">
      <div class="max-w-6xl mx-auto px-6 py-20">
        <h2 class="text-3xl font-bold text-white text-center mb-4">How HiveMind works</h2>
        <p class="text-gray-400 text-center max-w-xl mx-auto mb-16">
          Three layers. Each does exactly one job. None of them bleed into each other.
        </p>
        <div class="grid md:grid-cols-3 gap-6">
          <div class="bg-indigo-950/50 border border-indigo-900 rounded-xl p-6">
            <div class="text-xs font-mono text-indigo-400 mb-3">LAYER 1</div>
            <h3 class="text-lg font-semibold text-white mb-3">Write</h3>
            <p class="text-gray-400 text-sm leading-relaxed mb-4">
              An append-only event ledger. Every event carries actor, provenance, and
              a UUID. Anonymous writes are rejected. Smart behavior never touches the
              write path &mdash; the ledger stays unconditionally trustworthy.
            </p>
            <div class="bg-gray-900 rounded-lg p-3 font-mono text-xs text-gray-400">
              <span class="text-indigo-400">hivemind</span> emit decision.proposed<br/>
              &nbsp;&nbsp;--title &quot;Use SQLite for MVP&quot;<br/>
              &nbsp;&nbsp;--chose sqlite<br/>
              &nbsp;&nbsp;--actor human:alice
            </div>
          </div>
          <div class="bg-purple-950/50 border border-purple-900 rounded-xl p-6">
            <div class="text-xs font-mono text-purple-400 mb-3">LAYER 2</div>
            <h3 class="text-lg font-semibold text-white mb-3">Query</h3>
            <p class="text-gray-400 text-sm leading-relaxed mb-4">
              Pure deterministic reads. Status (<code class="text-purple-300">proposed</code>, <code class="text-purple-300">accepted</code>, <code class="text-purple-300">contested</code>, <code class="text-purple-300">superseded</code>)
              is derived from graph edges &mdash; never stored and never overwritten silently.
              No LLMs, no ranking, no inference.
            </p>
            <div class="bg-gray-900 rounded-lg p-3 font-mono text-xs text-gray-400">
              <span class="text-purple-400">hivemind</span> query search_decisions<br/>
              &nbsp;&nbsp;--topic architecture<br/>
              &nbsp;&nbsp;--status contested
            </div>
          </div>
          <div class="bg-emerald-950/50 border border-emerald-900 rounded-xl p-6">
            <div class="text-xs font-mono text-emerald-400 mb-3">LAYER 3</div>
            <h3 class="text-lg font-semibold text-white mb-3">Agentic</h3>
            <p class="text-gray-400 text-sm leading-relaxed mb-4">
              All intelligence lives here and only here &mdash; compactification,
              similarity, ranking, capture classification. Swappable without
              touching ingest or queries.
            </p>
            <div class="bg-gray-900 rounded-lg p-3 font-mono text-xs text-gray-400">
              <span class="text-emerald-400">hivemind</span> suggest<br/>
              &nbsp;&nbsp;document-candidates<br/>
              &nbsp;&nbsp;--file ./notes/memo.txt
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Features -->
    <section class="max-w-6xl mx-auto px-6 py-20">
      <h2 class="text-3xl font-bold text-white text-center mb-4">Built on honesty rails</h2>
      <p class="text-gray-400 text-center max-w-xl mx-auto mb-16">
        The properties that make HiveMind trustworthy are non-negotiable.
      </p>
      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6">
        <div class="flex gap-4">
          <div class="mt-1 flex-shrink-0 w-8 h-8 rounded-lg bg-indigo-900 flex items-center justify-center">
            <svg width="16" height="16" viewBox="0 0 16 16" fill="none"><path d="M2 8l4 4 8-8" stroke="#818cf8" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </div>
          <div>
            <h3 class="font-semibold text-white mb-1">Captured at the moment</h3>
            <p class="text-gray-400 text-sm">Decisions enter the ledger when they happen &mdash; with the options considered, the evidence cited, and the actor on record. Not reconstructed afterward.</p>
          </div>
        </div>
        <div class="flex gap-4">
          <div class="mt-1 flex-shrink-0 w-8 h-8 rounded-lg bg-indigo-900 flex items-center justify-center">
            <svg width="16" height="16" viewBox="0 0 16 16" fill="none"><path d="M2 8l4 4 8-8" stroke="#818cf8" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </div>
          <div>
            <h3 class="font-semibold text-white mb-1">Humans and agents as peers</h3>
            <p class="text-gray-400 text-sm">Every event carries an actor. Human decisions and agent decisions have the same shape and the same review surface.</p>
          </div>
        </div>
        <div class="flex gap-4">
          <div class="mt-1 flex-shrink-0 w-8 h-8 rounded-lg bg-indigo-900 flex items-center justify-center">
            <svg width="16" height="16" viewBox="0 0 16 16" fill="none"><path d="M2 8l4 4 8-8" stroke="#818cf8" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </div>
          <div>
            <h3 class="font-semibold text-white mb-1">Disagreement is preserved</h3>
            <p class="text-gray-400 text-sm"><code class="text-indigo-300">contested</code> is a first-class status, not an error. Two actors disagreeing is the signal, not noise to discard.</p>
          </div>
        </div>
        <div class="flex gap-4">
          <div class="mt-1 flex-shrink-0 w-8 h-8 rounded-lg bg-indigo-900 flex items-center justify-center">
            <svg width="16" height="16" viewBox="0 0 16 16" fill="none"><path d="M2 8l4 4 8-8" stroke="#818cf8" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </div>
          <div>
            <h3 class="font-semibold text-white mb-1">Supersession without deletion</h3>
            <p class="text-gray-400 text-sm">Old decisions are never deleted or mutated. A <code class="text-indigo-300">SUPERSEDES</code> edge preserves the full history of &ldquo;we changed our mind&rdquo; &mdash; and why.</p>
          </div>
        </div>
        <div class="flex gap-4">
          <div class="mt-1 flex-shrink-0 w-8 h-8 rounded-lg bg-indigo-900 flex items-center justify-center">
            <svg width="16" height="16" viewBox="0 0 16 16" fill="none"><path d="M2 8l4 4 8-8" stroke="#818cf8" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </div>
          <div>
            <h3 class="font-semibold text-white mb-1">No silent truncation</h3>
            <p class="text-gray-400 text-sm">Queries that hit limits return <code class="text-indigo-300">truncated: true</code>. A partial result that looks complete is a lie.</p>
          </div>
        </div>
        <div class="flex gap-4">
          <div class="mt-1 flex-shrink-0 w-8 h-8 rounded-lg bg-indigo-900 flex items-center justify-center">
            <svg width="16" height="16" viewBox="0 0 16 16" fill="none"><path d="M2 8l4 4 8-8" stroke="#818cf8" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </div>
          <div>
            <h3 class="font-semibold text-white mb-1">No invented confidence</h3>
            <p class="text-gray-400 text-sm">Agentic layer scores are traceable. &ldquo;Because the model said so&rdquo; is not acceptable provenance.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- Proof point / Self-audit -->
    <section class="border-t border-gray-800 bg-gray-900/30">
      <div class="max-w-6xl mx-auto px-6 py-20">
        <div class="bg-gradient-to-br from-indigo-950 to-purple-950 border border-indigo-800 rounded-2xl p-10 text-center">
          <div class="text-sm font-mono text-indigo-400 mb-4">THE SYSTEM AUDITS ITSELF &mdash; PRODUCTION FIDELITY RESULT</div>
          <div class="flex flex-col sm:flex-row justify-center gap-12 mb-8">
            <div>
              <div class="text-5xl font-bold text-white mb-2">~92%</div>
              <div class="text-gray-400 text-sm">of agent activity correctly<br/>identified as noise and skipped</div>
            </div>
            <div class="hidden sm:block w-px bg-indigo-800"></div>
            <div>
              <div class="text-5xl font-bold text-white mb-2">2000:1</div>
              <div class="text-gray-400 text-sm">compression ratio &mdash; decisions<br/>extracted from raw activity</div>
            </div>
          </div>
          <p class="text-gray-400 max-w-lg mx-auto text-sm leading-relaxed">
            HiveMind runs on itself. The capture classifier measures fidelity in production
            &mdash; not by dropping data, but by proving that almost all activity is legitimately noise.
          </p>
        </div>
      </div>
    </section>

    <!-- Who it's for -->
    <section class="max-w-6xl mx-auto px-6 py-20">
      <h2 class="text-3xl font-bold text-white text-center mb-4">Who it&rsquo;s for</h2>
      <p class="text-gray-400 text-center max-w-xl mx-auto mb-16">
        Anyone whose work produces decisions worth proving &mdash; and who increasingly makes them alongside agents.
      </p>
      <div class="grid md:grid-cols-2 gap-8">
        <div class="bg-gray-900 border border-gray-800 rounded-xl p-6">
          <h3 class="font-semibold text-white mb-3">Operators of agents</h3>
          <p class="text-gray-400 text-sm leading-relaxed">
            See what your agents decided the same way you see your own choices.
            Disagree with them when warranted &mdash; at the speed of a query, not the
            speed of reading a transcript. This is the defining use case.
          </p>
        </div>
        <div class="bg-gray-900 border border-gray-800 rounded-xl p-6">
          <h3 class="font-semibold text-white mb-3">Technical leaders</h3>
          <p class="text-gray-400 text-sm leading-relaxed">
            Review reasoning as structured decisions with options and evidence, not as shared chat URLs.
            Build a queryable record of architectural choices that survives
            team changes and agent generations.
          </p>
        </div>
        <div class="bg-gray-900 border border-gray-800 rounded-xl p-6">
          <h3 class="font-semibold text-white mb-3">Large organizations</h3>
          <p class="text-gray-400 text-sm leading-relaxed">
            Cross-team decision visibility without crawling a wiki. Compliance
            and audit teams get a provenance trail of who chose what, when, and
            on what evidence &mdash; and whether it&rsquo;s been superseded since.
          </p>
        </div>
        <div class="bg-gray-900 border border-gray-800 rounded-xl p-6">
          <h3 class="font-semibold text-white mb-3">Small teams shipping fast</h3>
          <p class="text-gray-400 text-sm leading-relaxed">
            Keep decision context alive past the conversation that created it.
            One agent&rsquo;s choice &mdash; with the options it considered &mdash; becomes
            the next agent&rsquo;s structured starting point, not a blank slate.
          </p>
        </div>
      </div>
    </section>

    <!-- Bottom CTA -->
    <section class="border-t border-gray-800 bg-gray-900/30">
      <div class="max-w-6xl mx-auto px-6 py-24 text-center">
        <h2 class="text-3xl font-bold text-white mb-4">Make your team&rsquo;s decisions honest, evidenced, and auditable</h2>
        <p class="text-gray-400 mb-10 max-w-lg mx-auto">
          HiveMind connects to Claude Code, Claude Desktop, or Cursor as an MCP server.
          Agents start capturing decisions the moment they make them &mdash; with options, evidence, and provenance built in.
        </p>
        <div class="flex flex-col sm:flex-row gap-4 justify-center">
          <a href={`${base}demo/`} class="bg-emerald-600 hover:bg-emerald-500 text-white px-8 py-3 rounded-lg font-semibold text-base transition-colors inline-block">
            Explore a real decision &rarr;
          </a>
          <a href={`${base}guides/mcp-setup/`} class="bg-indigo-600 hover:bg-indigo-500 text-white px-8 py-3 rounded-lg font-semibold text-base transition-colors inline-block">
            Connect your agent &rarr;
          </a>
          <a href={`${base}getting-started/install/`} class="border border-gray-700 hover:border-gray-500 text-gray-300 hover:text-white px-8 py-3 rounded-lg font-semibold text-base transition-colors inline-block">
            Self-host guide
          </a>
        </div>
      </div>
    </section>

  </main>

  <!-- Footer -->
  <footer class="border-t border-gray-800 py-12">
    <div class="max-w-6xl mx-auto px-6 flex flex-col sm:flex-row items-center justify-between gap-4">
      <div class="text-sm text-gray-500">
        HiveMind &mdash; honesty-backed decision memory
      </div>
      <div class="flex items-center gap-6 text-sm text-gray-500">
        <a href={`${base}guides/mcp-setup/`} class="hover:text-gray-300 transition-colors">MCP Setup</a>
        <a href={`${base}getting-started/install/`} class="hover:text-gray-300 transition-colors">Docs</a>
        <a href="https://github.com/alexknips/hivemind" class="hover:text-gray-300 transition-colors">GitHub</a>
      </div>
    </div>
  </footer>

</body>
</html>
